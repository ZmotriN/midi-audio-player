{
  "name": "midi-audio-player",
  "version": "1.0.3",
  "description": "Javascript Midi Audio Player for WebAudioFont",
  "keywords": [
    "audio",
    "player",
    "midi",
    "mid",
    "js",
    "webaudiofont"
  ],
  "homepage": "https://github.com/ZmotriN/midi-audio-player#readme",
  "bugs": {
    "url": "https://github.com/ZmotriN/midi-audio-player/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZmotriN/midi-audio-player.git"
  },
  "license": "MIT",
  "author": "Maxime Larrivée-Roy",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "unpkg": "./dist/midi-audio-player.min.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "script": "./dist/midi-audio-player.min.js"
    }
  },
  "scripts": {
    "build": "node scripts/watch.js --build-only",
    "dev": "node scripts/watch.js",
    "serve:site": "browser-sync start --server --startPath /site/ --files \"site/**/*.html, site/**/*.css, dist/index.js\""
  },
  "bin": {
    "webaudiofont": "./bin/cli.js"
  },
  "dependencies": {
    "midi-player-js": "^2.0.17"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "esbuild": "^0.28.0"
  }
}