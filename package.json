{
  "name": "midi-audio-player",
  "version": "1.2.0",
  "description": "Javascript Midi Audio Player for WebAudioFont",
  "keywords": [
    "midi",
    "midi-player",
    "webaudio",
    "webaudiofont",
    "audio",
    "music",
    "browser-audio",
    "midi-js",
    "web-audio-api",
    "midi-playback"
  ],
  "homepage": "https://zmotrin.github.io/midi-audio-player/",
  "bugs": {
    "url": "https://github.com/ZmotriN/midi-audio-player/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZmotriN/midi-audio-player.git"
  },
  "license": "MIT",
  "author": "Maxime Larrivée-Roy",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "unpkg": "./dist/midi-audio-player.min.js",
  "jsdelivr": "./dist/midi-audio-player.min.js",
  "files": [
    "dist",
    "bin",
    "src",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "script": "./dist/midi-audio-player.min.js"
    }
  },
  "scripts": {
    "build": "node scripts/watch.js --build",
    "dev": "node scripts/watch.js",
    "sass:build": "sass site/:site/ --no-source-map",
    "sass:watch": "sass site/:site/ --no-source-map --watch",
    "serve:site": "browser-sync start --server --startPath /site/ --files \"site/**/*.html, site/**/*.css, site/**/*.js, dist/**/*.js\""
  },
  "bin": {
    "webaudiofont": "./bin/cli.js"
  },
  "dependencies": {
    "midi-player-js": "^2.0.17"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "esbuild": "^0.28.0",
    "sass": "^1.99.0"
  },
  "engines": {
    "node": ">=18"
  }
}
